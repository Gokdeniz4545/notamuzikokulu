# Trendyol içe aktarma — gizli kimlik bilgileri şablonu.
# Bu dosyayı kopyalayıp `scripts/.env` yap ve gerçek değerleri gir.
# `scripts/.env` git'e gönderilmez (.gitignore). ASLA gerçek anahtarları buraya (.example) yazma.
#
# Çalıştırma:  node --env-file=scripts/.env scripts/trendyol-import.mjs

SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...   # service_role (gizli, RLS bypass) — sadece sunucu/araç

TRENDYOL_SUPPLIER_ID=1234567
TRENDYOL_API_KEY=xxxxxxxxxxxxxxxx
TRENDYOL_API_SECRET=xxxxxxxxxxxxxxxx
